# Copy to .env locally. Never commit .env or real values.

# Runtime
APP_ENV=development
APP_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Local companion
COMPANION_HOST=127.0.0.1
COMPANION_PORT=4317
COMPANION_PROJECT_ROOT=
COMPANION_PAIRING_TTL_SECONDS=300
COMPANION_COMMAND_TIMEOUT_SECONDS=120

# Database
DATABASE_URL=

# Authentication/session secrets
SESSION_SECRET=
ENCRYPTION_KEY=

# Optional AI providers
AI_PROVIDER=
AI_MODEL=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional deployment integrations
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
